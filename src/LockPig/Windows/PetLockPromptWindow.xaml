<Window x:Class="LockPig.Windows.PetLockPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440"
        Height="282"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Window.Resources>
        <FontFamily x:Key="PromptPixelFont">pack://application:,,,/LockCat;component/Assets/Fonts/#Fusion Pixel 12px Prop zh_hans</FontFamily>

        <Style x:Key="PromptButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="MinWidth" Value="124"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Foreground" Value="#3B2114"/>
            <Setter Property="FontFamily" Value="{StaticResource PromptPixelFont}"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="Shadow"
                                    Margin="3,4,0,0"
                                    Background="#7A4C24"/>
                            <Border x:Name="Body"
                                    Margin="0,0,3,4"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#7A4C24"
                                    BorderThickness="2">
                                <Grid>
                                    <Border Margin="3"
                                            BorderBrush="#FFE6A0"
                                            BorderThickness="1"/>
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Body" Property="BorderBrush" Value="#4F2E1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Body" Property="Margin" Value="3,4,0,0"/>
                                <Setter TargetName="Shadow" Property="Opacity" Value="0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#7A4C24"
            Padding="3"
            SnapsToDevicePixels="True">
        <Border Background="#FFF6DE"
                BorderBrush="#FFD15A"
                BorderThickness="2">
            <Grid Margin="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="44"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <Border Background="#FFE8A5"
                        BorderBrush="#C99A54"
                        BorderThickness="0,0,0,2"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid Margin="12,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
                        <Image Source="pack://application:,,,/LockCat;component/Assets/Pixel/cat-mini-24.png"
                               Width="24"
                               Height="24"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                        <TextBlock x:Name="TitleText"
                                   Grid.Column="1"
                                   Text="Triple-click lock"
                                   Foreground="#3B2114"
                                   FontFamily="{StaticResource PromptPixelFont}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="2"
                                Width="24"
                                Height="24"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="SkipButton_Click">
                            <TextBlock Text="x"
                                       Foreground="#3B2114"
                                       FontFamily="{StaticResource PromptPixelFont}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1"
                      Margin="28,22,28,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="82"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="64"
                            Height="64"
                            Background="#FFF1CF"
                            BorderBrush="#F3B832"
                            BorderThickness="2"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                        <Grid>
                            <Image Source="pack://application:,,,/LockCat;component/Assets/Pixel/cat-avatar-48.png"
                                   Width="48"
                                   Height="48"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                            <Image Source="pack://application:,,,/LockCat;component/Assets/Pixel/paw-16.png"
                                   Width="16"
                                   Height="16"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Bottom"
                                   Margin="0,0,3,3"/>
                        </Grid>
                    </Border>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="MessageText"
                                   TextWrapping="Wrap"
                                   Foreground="#3B2114"
                                   FontFamily="{StaticResource PromptPixelFont}"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   LineHeight="25"/>
                        <TextBlock x:Name="RemainingText"
                                   Margin="0,12,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="#806B5C"
                                   FontFamily="{StaticResource PromptPixelFont}"
                                   FontSize="13"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2"
                        Background="#FFF2D7"
                        BorderBrush="#E8C98D"
                        BorderThickness="0,2,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,24,0">
                        <Button x:Name="SkipButton"
                                Style="{StaticResource PromptButtonStyle}"
                                Background="#FFFCF1"
                                Margin="0,0,14,0"
                                Click="SkipButton_Click"/>
                        <Button x:Name="LockButton"
                                Style="{StaticResource PromptButtonStyle}"
                                Background="#FFD15A"
                                Click="LockButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Border>
</Window>
