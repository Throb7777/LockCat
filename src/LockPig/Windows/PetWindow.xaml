<Window x:Class="LockPig.Windows.PetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="180"
        Height="178"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Window.Resources>
        <FontFamily x:Key="PetPixelFont">pack://application:,,,/LockCat;component/Assets/Fonts/#Fusion Pixel 12px Prop zh_hans</FontFamily>
        <Style x:Key="PetMenuButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#3B2114"/>
            <Setter Property="FontFamily" Value="{StaticResource PetPixelFont}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#FFD15A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F2B326"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootLayer"
          Background="Transparent"
          RenderOptions.EdgeMode="Aliased"
          SnapsToDevicePixels="True"
          UseLayoutRounding="True"
          MouseLeftButtonDown="RootLayer_MouseLeftButtonDown"
          MouseLeftButtonUp="RootLayer_MouseLeftButtonUp"
          MouseMove="RootLayer_MouseMove"
          MouseRightButtonUp="RootLayer_MouseRightButtonUp"
          LostMouseCapture="RootLayer_LostMouseCapture">
        <Popup x:Name="PetMenuPopup"
               Placement="MousePoint"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="None">
            <Border Background="#7A4C24"
                    Padding="3"
                    SnapsToDevicePixels="True">
                <Border Background="#FFF6DE"
                        BorderBrush="#FFD15A"
                        BorderThickness="2"
                        Padding="5">
                    <StackPanel Width="176">
                        <Border Background="#FFD15A"
                                BorderBrush="#7A4C24"
                                BorderThickness="1"
                                Padding="6,4"
                                Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>
                                <Image Source="pack://application:,,,/LockCat;component/Assets/Pixel/cat-mini-24.png"
                                       Width="20"
                                       Height="20"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <TextBlock Grid.Column="1"
                                           Text="LockCat"
                                           Foreground="#3B2114"
                                           FontFamily="{StaticResource PetPixelFont}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2"
                                           Text="✓"
                                           Foreground="#7A4C24"
                                           FontFamily="{StaticResource PetPixelFont}"
                                           FontSize="12"
                                           FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <Button Style="{StaticResource PetMenuButtonStyle}" Click="LockMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="■" Foreground="#B97718"/>
                                <TextBlock x:Name="PetMenuLockText" Grid.Column="1" Text="立即锁定"/>
                                <TextBlock Grid.Column="2" Text="›" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource PetMenuButtonStyle}" Click="SettingsMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚙" Foreground="#B97718"/>
                                <TextBlock x:Name="PetMenuSettingsText" Grid.Column="1" Text="打开设置"/>
                                <TextBlock Grid.Column="2" Text="›" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>
                        <Button x:Name="PauseAnimationButton" Style="{StaticResource PetMenuButtonStyle}" Click="PauseAnimationMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Ⅱ" Foreground="#B97718"/>
                                <TextBlock x:Name="PauseAnimationText" Grid.Column="1" Text="暂停动画"/>
                                <TextBlock Grid.Column="2" Text="›" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>
                        <Button x:Name="TopmostButton" Style="{StaticResource PetMenuButtonStyle}" Click="TopmostMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="▲" Foreground="#B97718"/>
                                <TextBlock x:Name="TopmostText" Grid.Column="1" Text="小猫置顶"/>
                                <TextBlock Grid.Column="2" Text="›" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource PetMenuButtonStyle}" Click="HideMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="●" Foreground="#B97718"/>
                                <TextBlock x:Name="PetMenuHideText" Grid.Column="1" Text="隐藏小猫"/>
                                <TextBlock Grid.Column="2" Text="›" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>

                        <Border Height="2" Background="#E8C98D" Margin="3,4"/>
                        <Button Style="{StaticResource PetMenuButtonStyle}" Click="ExitMenuItem_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="×" Foreground="#B45B4F"/>
                                <TextBlock x:Name="PetMenuExitText" Grid.Column="1" Text="退出 LockCat" Foreground="#6E2D24"/>
                                <TextBlock Grid.Column="2" Text="›" Foreground="#6E2D24" HorizontalAlignment="Right"/>
                            </Grid>
                        </Button>
                    </StackPanel>
                </Border>
            </Border>
        </Popup>

        <Border x:Name="SpeechBubble"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,5,0,0"
                Padding="8,4"
                Background="#FFFFF4"
                BorderBrush="#7A4C24"
                BorderThickness="2"
                Opacity="0"
                Visibility="Collapsed">
            <Grid>
                <Border Margin="2"
                        BorderBrush="#FFD15A"
                        BorderThickness="1"/>
                <TextBlock x:Name="MoodText"
                           Margin="5,1"
                           Text="待机"
                           Foreground="#3B2114"
                           FontFamily="{StaticResource PetPixelFont}"
                           FontSize="13"
                           FontWeight="Bold"/>
            </Grid>
        </Border>

        <TextBlock x:Name="EffectText"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Margin="0,31,0,0"
                   Text=""
                   Foreground="#F2B326"
                   FontFamily="{StaticResource PetPixelFont}"
                   FontSize="22"
                   FontWeight="Bold"
                   Opacity="0"/>

        <Canvas x:Name="SparkCanvas"
                Width="180"
                Height="178"
                IsHitTestVisible="False">
            <Rectangle x:Name="SparkA" Width="5" Height="5" Fill="#FFD15A" Canvas.Left="135" Canvas.Top="58" Opacity="0"/>
            <Rectangle x:Name="SparkB" Width="4" Height="4" Fill="#F3B73E" Canvas.Left="40" Canvas.Top="90" Opacity="0"/>
            <Rectangle x:Name="SparkC" Width="3" Height="3" Fill="#FFE7A1" Canvas.Left="118" Canvas.Top="112" Opacity="0"/>
        </Canvas>

        <Rectangle x:Name="GroundShadow"
                   Width="88"
                   Height="8"
                   Fill="#6F4B2A"
                   Opacity="0.14"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,8"/>

        <Image x:Name="CatSprite"
               Width="152"
               Height="132"
               HorizontalAlignment="Center"
               VerticalAlignment="Bottom"
               Margin="0,0,0,12"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               SnapsToDevicePixels="True">
            <Image.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="CatScale" ScaleX="1" ScaleY="1" CenterX="76" CenterY="118"/>
                    <TranslateTransform x:Name="CatTranslate" X="0" Y="0"/>
                </TransformGroup>
            </Image.RenderTransform>
        </Image>
    </Grid>
</Window>
