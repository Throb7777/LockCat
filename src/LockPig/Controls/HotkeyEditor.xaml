<UserControl x:Class="LockPig.Controls.HotkeyEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="48"
             SnapsToDevicePixels="True"
             PreviewMouseLeftButtonDown="HotkeyEditor_PreviewMouseLeftButtonDown">
    <UserControl.Resources>
        <Style x:Key="PixelKeycapTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="48"/>
            <Setter Property="MinWidth" Value="136"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#A1733F"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource LcTextBrush}"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/LockCat;component/Assets/Fonts/#Fusion Pixel 12px Prop zh_hans"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{DynamicResource LcTextBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource LcAccentBrush}"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="Aliased"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid x:Name="KeycapRoot" RenderOptions.EdgeMode="Aliased">
                            <Image x:Name="Chrome"
                                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-keycap-bg-soft.png"
                                   Width="136"
                                   Height="48"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True"/>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="12,-2,14,6"
                                          VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="KeycapRoot" Property="Margin" Value="2,2,-2,-2"/>
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.95"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.97"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A89A72"/>
            <Setter Property="FontFamily" Value="pack://application:,,,/LockCat;component/Assets/Fonts/#Fusion Pixel 12px Prop zh_hans"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="136"/>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="136"/>
            <ColumnDefinition Width="44"/>
            <ColumnDefinition Width="136"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="SlotOne"
                 Grid.Column="0"
                 Style="{StaticResource PixelKeycapTextBox}"
                 PreviewKeyDown="Slot_PreviewKeyDown"
                 LostKeyboardFocus="Slot_LostKeyboardFocus"/>
        <TextBlock Grid.Column="1"
                   Text="+"
                   Style="{StaticResource PlusText}"/>
        <TextBox x:Name="SlotTwo"
                 Grid.Column="2"
                 Style="{StaticResource PixelKeycapTextBox}"
                 PreviewKeyDown="Slot_PreviewKeyDown"
                 LostKeyboardFocus="Slot_LostKeyboardFocus"/>
        <TextBlock Grid.Column="3"
                   Text="+"
                   Style="{StaticResource PlusText}"/>
        <TextBox x:Name="SlotThree"
                 Grid.Column="4"
                 Style="{StaticResource PixelKeycapTextBox}"
                 PreviewKeyDown="Slot_PreviewKeyDown"
                 LostKeyboardFocus="Slot_LostKeyboardFocus"/>
    </Grid>
</UserControl>
