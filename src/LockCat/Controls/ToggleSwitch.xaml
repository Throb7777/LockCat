<UserControl x:Class="LockPig.Controls.ToggleSwitch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="98"
             Height="47"
             Focusable="True"
             Cursor="Hand"
             SnapsToDevicePixels="True"
             KeyDown="ToggleSwitch_KeyDown"
             MouseLeftButtonDown="ToggleSwitch_MouseLeftButtonDown"
             MouseLeftButtonUp="ToggleSwitch_MouseLeftButtonUp"
             MouseLeave="ToggleSwitch_MouseLeave">
    <Grid x:Name="SwitchRoot"
          RenderOptions.BitmapScalingMode="NearestNeighbor"
          SnapsToDevicePixels="True">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="PressTransform"/>
        </Grid.RenderTransform>
        <Grid Width="98" Height="47" ClipToBounds="False">
            <Image x:Name="OffTrackImage"
                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-toggle-track-off-final.png"
                   Width="98"
                   Height="47"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   Opacity="1"/>
            <Image x:Name="OnTrackImage"
                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-toggle-track-on-final.png"
                   Width="98"
                   Height="47"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   Opacity="0"/>
            <Image x:Name="ThumbImage"
                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-toggle-thumb.png"
                   Width="46"
                   Height="47"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Stretch="None"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   SnapsToDevicePixels="True">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="ThumbTransform"/>
                </Image.RenderTransform>
            </Image>
        </Grid>
    </Grid>
</UserControl>
