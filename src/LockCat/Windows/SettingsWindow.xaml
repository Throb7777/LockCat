<Window x:Class="LockPig.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:LockPig.Controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="LockCat 设置"
        Icon="pack://application:,,,/LockCat;component/Assets/Icons/LockCat.ico"
        Width="1160"
        Height="920"
        MinWidth="980"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None"
        Background="{DynamicResource LcPageBrush}"
        FontFamily="Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="Aliased"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        Deactivated="Window_Deactivated"
        StateChanged="Window_StateChanged"
        PreviewMouseDown="Window_PreviewMouseDown"
        PreviewKeyDown="Window_PreviewKeyDown">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="52"
                            ResizeBorderThickness="6"
                            CornerRadius="4"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <FontFamily x:Key="LcPixelFont">pack://application:,,,/LockCat;component/Assets/Fonts/#Fusion Pixel 12px Prop zh_hans</FontFamily>
        <DropShadowEffect x:Key="LcPanelShadow" BlurRadius="12" ShadowDepth="5" Direction="270" Opacity="0.16"/>
        <DrawingBrush x:Key="FooterCheckerBrush"
                      TileMode="Tile"
                      Viewport="0,0,16,16"
                      ViewportUnits="Absolute"
                      Stretch="None">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <GeometryDrawing Brush="#FFF0D2">
                        <GeometryDrawing.Geometry>
                            <RectangleGeometry Rect="0,0,16,16"/>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                    <GeometryDrawing Brush="#FFF6E4">
                        <GeometryDrawing.Geometry>
                            <GeometryGroup>
                                <RectangleGeometry Rect="0,0,8,8"/>
                                <RectangleGeometry Rect="8,8,8,8"/>
                            </GeometryGroup>
                        </GeometryDrawing.Geometry>
                    </GeometryDrawing>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>

        <Style x:Key="TitleButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LcTextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#22F3BC23"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#36B8751A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PixelButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LcTextBrush}"/>
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonRoot" Background="Transparent" RenderOptions.EdgeMode="Aliased">
                            <Image x:Name="ButtonChrome"
                                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-button-normal-bg.png"
                                   Width="170"
                                   Height="60"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   IsHitTestVisible="False"/>
                            <controls:PixelTextBlock Text="{TemplateBinding Content}"
                                                     IsHitTestVisible="False"
                                                     FontSize="{TemplateBinding FontSize}"
                                                     FontWeight="{TemplateBinding FontWeight}"
                                                     Foreground="{TemplateBinding Foreground}"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Margin="0,-3,4,7"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.96"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Margin" Value="3,3,-3,-3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.68"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryPixelButtonStyle" TargetType="Button" BasedOn="{StaticResource PixelButtonStyle}">
            <Setter Property="Width" Value="216"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="ButtonRoot" Background="Transparent" RenderOptions.EdgeMode="Aliased">
                            <Image x:Name="ButtonChrome"
                                   Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-button-primary-bg.png"
                                   Width="216"
                                   Height="60"
                                   Stretch="None"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   IsHitTestVisible="False"/>
                            <controls:PixelTextBlock Text="{TemplateBinding Content}"
                                                     IsHitTestVisible="False"
                                                     FontSize="{TemplateBinding FontSize}"
                                                     FontWeight="{TemplateBinding FontWeight}"
                                                     Foreground="{TemplateBinding Foreground}"
                                                     Margin="-10,-3,27,7"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                            <controls:PixelIcon Kind="PawButton"
                                                IsHitTestVisible="False"
                                                Width="30"
                                                Height="29"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,-3,24,7"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.96"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Margin" Value="3,3,-3,-3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.72"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AnchorButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="AnchorChrome" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="AnchorChrome" Property="Background" Value="#18F3BC23"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PopupItemStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource LcTextBrush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ItemChrome" Background="{TemplateBinding Background}">
                            <controls:PixelTextBlock Text="{TemplateBinding Content}"
                                                     FontSize="{TemplateBinding FontSize}"
                                                     FontWeight="{TemplateBinding FontWeight}"
                                                     Foreground="{TemplateBinding Foreground}"
                                                     PixelScale="0.72"
                                                     Margin="{TemplateBinding Padding}"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{DynamicResource LcAccentPaleBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="10"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="Background" Value="#45FFF0D2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="ScrollRoot"
                              Width="10"
                              Margin="0,7,2,7"
                              Background="Transparent"
                              SnapsToDevicePixels="True">
                            <Border Width="4"
                                    HorizontalAlignment="Center"
                                    Background="#33DCA54A"
                                    BorderBrush="#55F7D894"
                                    BorderThickness="1"
                                    CornerRadius="3"/>
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  Opacity="0"/>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb MinHeight="34">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border x:Name="ThumbChrome"
                                                        Width="8"
                                                        Background="#F2B326"
                                                        BorderBrush="#7A4C24"
                                                        BorderThickness="1"
                                                        CornerRadius="4"/>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbChrome" Property="Background" Value="#FFD15A"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter TargetName="ThumbChrome" Property="Background" Value="#D8911D"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}"
                                                  Background="Transparent"
                                                  BorderBrush="Transparent"
                                                  Opacity="0"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PixelSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Track x:Name="PART_Track" VerticalAlignment="Center">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="8" Background="{DynamicResource LcAccentBrush}" BorderBrush="{DynamicResource LcBorderStrongBrush}" BorderThickness="1"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="8" Background="{DynamicResource LcAccentPaleBrush}" BorderBrush="{DynamicResource LcBorderBrush}" BorderThickness="1"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Width="18" Height="22">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border Background="{DynamicResource LcCardBrush}" BorderBrush="{DynamicResource LcBorderStrongBrush}" BorderThickness="2"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root" ClipToBounds="True" Background="{DynamicResource LcPageBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="104"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="#6E4926"
                BorderThickness="0,0,0,2">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#FFFFFBF0" Offset="0"/>
                    <GradientStop Color="#FFFFF2D2" Offset="0.54"/>
                    <GradientStop Color="#FFF1C97D" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                    <controls:PixelCatAvatar Variant="Title" Width="36" Height="31" Margin="0,0,16,0"/>
                    <controls:PixelTextBlock x:Name="TitleText"
                                             Text="LockCat 设置"
                                             Foreground="{DynamicResource LcTextBrush}"
                                             FontSize="21"
                                             FontWeight="Black"
                                             VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,18,0">
                    <Button Style="{StaticResource TitleButtonStyle}" Click="Minimize_Click">
                        <controls:PixelIcon Kind="WindowMinimize" Width="30" Height="30"/>
                    </Button>
                    <Button x:Name="MaximizeButton" Style="{StaticResource TitleButtonStyle}" Click="MaximizeRestore_Click">
                        <controls:PixelIcon x:Name="MaximizeIcon" Kind="WindowMaximize" Width="30" Height="30"/>
                    </Button>
                    <Button Style="{StaticResource TitleButtonStyle}" Click="CloseWindow_Click">
                        <controls:PixelIcon Kind="WindowClose" Width="30" Height="30"/>
                    </Button>
                </StackPanel>
                <Border Grid.ColumnSpan="2" Height="2" VerticalAlignment="Top" Background="#FFFFFFFF" Margin="6,3,6,0" Opacity="0.85" IsHitTestVisible="False"/>
                <Border Grid.ColumnSpan="2" Height="1" VerticalAlignment="Bottom" Background="#FFF7D894" Margin="4,0,4,5" IsHitTestVisible="False"/>
                <Border Grid.ColumnSpan="2" Height="2" VerticalAlignment="Bottom" Background="#D5A057" Margin="3,0,3,3" IsHitTestVisible="False"/>
                <Border Grid.ColumnSpan="2" Height="2" VerticalAlignment="Bottom" Background="#7B532C" Margin="0,0,0,0" IsHitTestVisible="False"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.Background>
                <RadialGradientBrush Center="0.48,0.48" GradientOrigin="0.48,0.48" RadiusX="0.74" RadiusY="0.86">
                    <GradientStop Color="{DynamicResource LcCardColor}" Offset="0"/>
                    <GradientStop Color="{DynamicResource LcPageColor}" Offset="0.60"/>
                    <GradientStop Color="{DynamicResource LcPageSoftColor}" Offset="1"/>
                </RadialGradientBrush>
            </Grid.Background>

            <ScrollViewer x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          PanningMode="VerticalOnly">
                <Grid x:Name="RootGrid"
                      Width="{Binding ActualWidth, ElementName=ContentScroll}"
                      MaxWidth="1040"
                      MinWidth="900"
                      Margin="0,0,0,0"
                      HorizontalAlignment="Center">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="RootTranslate" Y="8"/>
                    </Grid.RenderTransform>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="124"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <StackPanel VerticalAlignment="Top" Margin="14,20,0,0">
                            <Image Source="pack://application:,,,/LockCat;component/Assets/Pixel/target-logo.png"
                                   Width="326"
                                   Height="70"
                                   HorizontalAlignment="Left"
                                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                                   SnapsToDevicePixels="True"/>
                            <StackPanel Orientation="Horizontal" Margin="0,7,0,0">
                                <controls:PixelTextBlock x:Name="HeroSubtitleText"
                                                         Text="让小猫帮你暂时锁住键盘和屏幕"
                                                         Foreground="{DynamicResource LcTextMutedBrush}"
                                                         FontSize="18"
                                                         FontWeight="SemiBold"/>
                                <controls:PixelIcon Kind="Paw" Width="24" Height="22" Margin="12,-1,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <controls:PixelCatAvatar Variant="Peek"
                                                 Width="148"
                                                 Height="108"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0,18,26,0"/>
                    </Grid>

                    <StackPanel Grid.Row="1">
                        <controls:PixelFrame Width="{Binding ActualWidth, ElementName=RootGrid}"
                                             Height="192"
                                             Margin="0,0,0,6"
                                             Padding="22,10,22,8"
                                             Cut="10"
                                             ShadowOffset="5"
                                             Background="{DynamicResource LcCardBrush}"
                                             BorderBrush="{DynamicResource LcBorderStrongBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="106"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <controls:PixelIcon Kind="KeyboardTile" Width="78" Height="72" Margin="0,3,0,0" VerticalAlignment="Top"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="23"/>
                                        <RowDefinition Height="9"/>
                                        <RowDefinition Height="45"/>
                                        <RowDefinition Height="5"/>
                                        <RowDefinition Height="45"/>
                                    </Grid.RowDefinitions>
                                    <controls:PixelTextBlock x:Name="ShortcutSectionText" Text="快捷键" Foreground="{DynamicResource LcTextBrush}" FontSize="26" FontWeight="Black"/>
                                    <controls:PixelTextBlock x:Name="ShortcutDescriptionText" Grid.Row="1" Text="点击键帽可重新设置组合键。" Foreground="{DynamicResource LcTextMutedBrush}" FontSize="15" FontWeight="SemiBold" Margin="0,4,0,0"/>
                                    <Rectangle Grid.Row="4" Height="2" Fill="{DynamicResource LcAccentPaleBrush}" StrokeDashArray="3,3" Margin="0,0,66,0"/>
                                    <Grid Grid.Row="3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="236"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <controls:PixelIcon Kind="Paw" Width="22" Height="20" Margin="-3,0,14,0"/>
                                            <controls:PixelTextBlock x:Name="LockHotkeyLabelText" Text="锁定快捷键" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Black"/>
                                        </StackPanel>
                                        <controls:HotkeyEditor x:Name="LockHotkeyEditor" Grid.Column="1" Width="496" Margin="20,0,0,0" HorizontalAlignment="Left" GestureChanged="SettingsValue_Changed"/>
                                    </Grid>
                                    <Grid Grid.Row="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="236"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <controls:PixelIcon Kind="Paw" Width="22" Height="20" Margin="-3,0,14,0"/>
                                            <controls:PixelTextBlock x:Name="UnlockHotkeyLabelText" Text="恢复快捷键" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Black"/>
                                        </StackPanel>
                                        <controls:HotkeyEditor x:Name="UnlockHotkeyEditor" Grid.Column="1" Width="496" Margin="20,0,0,0" HorizontalAlignment="Left" GestureChanged="SettingsValue_Changed"/>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </controls:PixelFrame>

                        <controls:PixelFrame Width="{Binding ActualWidth, ElementName=RootGrid}"
                                             Height="120"
                                             Margin="0,0,0,6"
                                             Padding="22,11,22,10"
                                             Cut="10"
                                             ShadowOffset="5"
                                             Background="{DynamicResource LcCardBrush}"
                                             BorderBrush="{DynamicResource LcBorderStrongBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="106"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="126"/>
                                </Grid.ColumnDefinitions>
                                <controls:PixelIcon Kind="LockTile" Width="78" Height="71" Margin="0,2,0,0" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1">
                                    <controls:PixelTextBlock x:Name="LockBehaviorSectionText" Text="锁定行为" Foreground="{DynamicResource LcTextBrush}" FontSize="26" FontWeight="Black"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,11,0,0">
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource LcAccentBrush}" Margin="0,6,20,0"/>
                                        <StackPanel>
                                            <controls:PixelTextBlock x:Name="TurnOffMonitorText" Text="锁定时关闭屏幕" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Bold"/>
                                            <controls:PixelTextBlock x:Name="TurnOffMonitorDescriptionText" Text="锁定后自动关闭显示器，不会让系统进入睡眠。" Foreground="{DynamicResource LcTextMutedBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                                    <controls:ToggleSwitch x:Name="TurnOffMonitorSwitch" HorizontalAlignment="Right" CheckedChanged="SettingsValue_Changed"/>
                                    <Button x:Name="MonitorModeAnchor"
                                            Margin="0,6,4,0"
                                            HorizontalAlignment="Right"
                                            Style="{StaticResource AnchorButtonStyle}"
                                            Click="MonitorModeAnchor_Click">
                                        <StackPanel Orientation="Horizontal">
                                            <controls:PixelTextBlock x:Name="MonitorPowerModeValueText" Text="高级" Foreground="{DynamicResource LcTextBrush}" FontSize="17" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            <controls:PixelTextBlock Text="  ›" Foreground="{DynamicResource LcTextBrush}" FontSize="20" FontWeight="Black" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </controls:PixelFrame>

                        <controls:PixelFrame Width="{Binding ActualWidth, ElementName=RootGrid}"
                                             Height="152"
                                             Margin="0,0,0,6"
                                             Padding="22,10,22,10"
                                             Cut="10"
                                             ShadowOffset="5"
                                             Background="{DynamicResource LcCardBrush}"
                                             BorderBrush="{DynamicResource LcBorderStrongBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="106"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="126"/>
                                </Grid.ColumnDefinitions>
                                <controls:PixelIcon Kind="CatTile" Width="78" Height="70" Margin="0,1,0,0" VerticalAlignment="Top"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="30"/>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>
                                    <controls:PixelTextBlock x:Name="CatAppearanceSectionText" Text="小猫外观" Foreground="{DynamicResource LcTextBrush}" FontSize="26" FontWeight="Black"/>
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource LcAccentBrush}" Margin="0,8,20,0"/>
                                        <StackPanel>
                                            <controls:PixelTextBlock x:Name="ShowPetText" Text="显示桌面小猫" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Bold"/>
                                            <controls:PixelTextBlock x:Name="ShowPetDescriptionText" Text="隐藏后可从托盘或设置页重新显示小猫。" Foreground="{DynamicResource LcTextMutedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Rectangle Grid.Row="2" Fill="{DynamicResource LcAccentPaleBrush}" StrokeDashArray="3,3" Opacity="0.95" Margin="0,0,22,0"/>
                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,4,0,0">
                                        <Rectangle Width="10" Height="10" Fill="{DynamicResource LcAccentBrush}" Margin="0,8,20,0"/>
                                        <StackPanel>
                                            <controls:PixelTextBlock x:Name="AlwaysOnTopText" Text="小猫保持置顶" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Bold"/>
                                            <controls:PixelTextBlock x:Name="AlwaysOnTopDescriptionText" Text="让 LockCat 小猫一直显示在其他窗口上方。" Foreground="{DynamicResource LcTextMutedBrush}" FontSize="13" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                                <Grid Grid.Column="2" Margin="0,30,6,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="50"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="50"/>
                                    </Grid.RowDefinitions>
                                    <controls:ToggleSwitch x:Name="ShowPetSwitch" HorizontalAlignment="Right" VerticalAlignment="Center" CheckedChanged="SettingsValue_Changed"/>
                                    <controls:ToggleSwitch x:Name="AlwaysOnTopSwitch" Grid.Row="2" HorizontalAlignment="Right" VerticalAlignment="Center" CheckedChanged="SettingsValue_Changed"/>
                                </Grid>
                                <Grid Grid.ColumnSpan="3"
                                      Height="28"
                                      Opacity="0.42"
                                      Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="270"/>
                                        <ColumnDefinition Width="58"/>
                                    </Grid.ColumnDefinitions>
                                    <controls:PixelTextBlock Text="透明度" Foreground="{DynamicResource LcTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    <Slider x:Name="PetOpacitySlider"
                                            Grid.Column="1"
                                            Style="{StaticResource PixelSliderStyle}"
                                            Minimum="20"
                                            Maximum="100"
                                            TickFrequency="10"
                                            ValueChanged="PetOpacitySlider_ValueChanged"
                                            VerticalAlignment="Center"/>
                                    <controls:PixelTextBlock x:Name="PetOpacityValueText"
                                                            Grid.Column="2"
                                                            Text="100%"
                                                            Foreground="{DynamicResource LcTextBrush}"
                                                            FontSize="12"
                                                            FontWeight="SemiBold"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"/>
                                </Grid>
                            </Grid>
                        </controls:PixelFrame>

                        <controls:PixelFrame Width="{Binding ActualWidth, ElementName=RootGrid}"
                                             Height="128"
                                             Margin="0,0,0,0"
                                             Padding="22,9,22,8"
                                             Cut="10"
                                             ShadowOffset="5"
                                             Background="{DynamicResource LcCardBrush}"
                                             BorderBrush="{DynamicResource LcBorderStrongBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="106"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <controls:PixelIcon Kind="GearTile" Width="78" Height="71" Margin="0,2,0,0" VerticalAlignment="Top"/>
                                <Grid Grid.Column="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="43"/>
                                        <RowDefinition Height="2"/>
                                        <RowDefinition Height="34"/>
                                    </Grid.RowDefinitions>
                                    <controls:PixelTextBlock x:Name="StartupLanguageSectionText" Text="启动与语言" Foreground="{DynamicResource LcTextBrush}" FontSize="26" FontWeight="Black"/>
                                    <Grid Grid.Row="1" Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="136"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Rectangle Width="10" Height="10" Fill="{DynamicResource LcAccentBrush}" Margin="0,0,20,0"/>
                                            <controls:PixelTextBlock x:Name="StartWithWindowsText" Text="开机自启动" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Bold"/>
                                        </StackPanel>
                                        <controls:ToggleSwitch x:Name="StartWithWindowsSwitch" Grid.Column="1" Margin="0,0,6,0" HorizontalAlignment="Right" VerticalAlignment="Center" CheckedChanged="SettingsValue_Changed"/>
                                    </Grid>
                                    <Rectangle Grid.Row="2" Fill="{DynamicResource LcAccentPaleBrush}" StrokeDashArray="3,3" Opacity="0.95" Margin="0,0,22,0"/>
                                    <Grid Grid.Row="3" Margin="0,2,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Rectangle Width="10" Height="10" Fill="{DynamicResource LcAccentBrush}" Margin="0,0,20,0"/>
                                            <controls:PixelTextBlock x:Name="InterfaceLanguageText" Text="界面语言" Foreground="{DynamicResource LcTextBrush}" FontSize="19" FontWeight="Bold"/>
                                        </StackPanel>
                                        <Button x:Name="LanguageAnchor"
                                                Grid.Column="1"
                                                Style="{StaticResource AnchorButtonStyle}"
                                                Click="LanguageAnchor_Click">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <controls:PixelTextBlock x:Name="LanguageValueText" Text="中文" Foreground="{DynamicResource LcTextBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <controls:PixelTextBlock Text="  ›" Foreground="{DynamicResource LcTextBrush}" FontSize="22" FontWeight="Black" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Grid>
                        </controls:PixelFrame>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Popup x:Name="LanguagePopup"
                   PlacementTarget="{Binding ElementName=LanguageAnchor}"
                   Placement="Custom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <controls:PixelFrame Width="170" Padding="8" Cut="8" ShadowOffset="5" Background="{DynamicResource LcCardBrush}" BorderBrush="{DynamicResource LcBorderStrongBrush}">
                    <StackPanel>
                        <Button x:Name="ChineseLanguageButton" Content="✓ 中文" Style="{StaticResource PopupItemStyle}" Click="ChineseLanguage_Click"/>
                        <Button x:Name="EnglishLanguageButton" Content="  English" Style="{StaticResource PopupItemStyle}" Click="EnglishLanguage_Click"/>
                        <Button x:Name="JapaneseLanguageButton" Content="  日本語" Style="{StaticResource PopupItemStyle}" Click="JapaneseLanguage_Click"/>
                    </StackPanel>
                </controls:PixelFrame>
            </Popup>

            <Popup x:Name="MonitorModePopup"
                   PlacementTarget="{Binding ElementName=MonitorModeAnchor}"
                   Placement="Custom"
                   StaysOpen="True"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <controls:PixelFrame Width="310" Padding="8" Cut="8" ShadowOffset="5" Background="{DynamicResource LcCardBrush}" BorderBrush="{DynamicResource LcBorderStrongBrush}">
                    <StackPanel>
                        <Button x:Name="HardwareDdcButton" Content="✓ 硬件 DDC/CI" Style="{StaticResource PopupItemStyle}" Click="HardwareDdc_Click"/>
                        <Button x:Name="WindowsPowerMessageButton" Content="  Windows 兼容关屏" Style="{StaticResource PopupItemStyle}" Click="WindowsPowerMessage_Click"/>
                        <Button x:Name="DetectMonitorButton" Content="  重新检测显示器" Style="{StaticResource PopupItemStyle}" Click="DetectMonitor_Click"/>
                    </StackPanel>
                </controls:PixelFrame>
            </Popup>
        </Grid>

        <Border Grid.Row="2"
                Background="{StaticResource FooterCheckerBrush}"
                BorderBrush="{DynamicResource LcBorderStrongBrush}"
                BorderThickness="0,3,0,0">
            <Grid>
                <controls:PixelIcon Kind="PawFooterLeft" Width="42" Height="40" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="42,7,0,0" Opacity="0.48"/>
                <controls:PixelIcon Kind="PawFooterRight" Width="42" Height="40" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,7,42,0" Opacity="0.48"/>
                <controls:PixelFrame HorizontalAlignment="Left"
                                     VerticalAlignment="Center"
                                     Width="488"
                                     Height="72"
                                     Margin="90,0,0,0"
                                     Padding="22,9,20,9"
                                     Cut="8"
                                     ShadowOffset="5"
                                     Background="{DynamicResource LcCardBrush}"
                                     BorderBrush="{DynamicResource LcBorderStrongBrush}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <controls:PixelIcon Kind="PawStatus" Width="34" Height="33" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        <controls:PixelTextBlock x:Name="DirtyStateText" Grid.Column="1" Text="设置已同步" Foreground="{DynamicResource LcTextBrush}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,0,1"/>
                    </Grid>
                </controls:PixelFrame>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,96,0">
                    <Button x:Name="CancelButton" Content="取消" AutomationProperties.Name="取消" Style="{StaticResource PixelButtonStyle}" Click="Cancel_Click"/>
                    <Button x:Name="SaveButton" Content="保存更改" AutomationProperties.Name="保存更改" Style="{StaticResource PrimaryPixelButtonStyle}" Click="Save_Click" Margin="22,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.RowSpan="3"
                BorderBrush="#75502B"
                BorderThickness="4"
                CornerRadius="2"
                IsHitTestVisible="False"/>
        <Border Grid.RowSpan="3"
                Margin="6"
                BorderBrush="#FFE3A5"
                BorderThickness="2"
                CornerRadius="1"
                IsHitTestVisible="False"/>
    </Grid>
</Window>

