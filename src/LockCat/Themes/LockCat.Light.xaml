<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="LcPageColor">#FFF4DF</Color>
    <Color x:Key="LcPageSoftColor">#FFEAC4</Color>
    <Color x:Key="LcCardColor">#FFFCF1</Color>
    <Color x:Key="LcCardAltColor">#FFF8E7</Color>
    <Color x:Key="LcAccentColor">#F3B832</Color>
    <Color x:Key="LcAccentSoftColor">#FFE8A5</Color>
    <Color x:Key="LcAccentPaleColor">#FFF1CF</Color>
    <Color x:Key="LcTextColor">#2D2017</Color>
    <Color x:Key="LcTextMutedColor">#806B5C</Color>
    <Color x:Key="LcBorderColor">#E8C98D</Color>
    <Color x:Key="LcBorderStrongColor">#C99A54</Color>
    <Color x:Key="LcKeyEdgeColor">#76543A</Color>
    <Color x:Key="LcToggleOffColor">#CCCAC5</Color>
    <Color x:Key="LcErrorColor">#D85B53</Color>
    <Color x:Key="LcSuccessColor">#57B94A</Color>
    <Color x:Key="LcWindowTitleColor">#FFFCF5</Color>

    <SolidColorBrush x:Key="LcPageBrush" Color="{StaticResource LcPageColor}"/>
    <SolidColorBrush x:Key="LcPageSoftBrush" Color="{StaticResource LcPageSoftColor}"/>
    <SolidColorBrush x:Key="LcCardBrush" Color="{StaticResource LcCardColor}"/>
    <SolidColorBrush x:Key="LcCardAltBrush" Color="{StaticResource LcCardAltColor}"/>
    <SolidColorBrush x:Key="LcAccentBrush" Color="{StaticResource LcAccentColor}"/>
    <SolidColorBrush x:Key="LcAccentSoftBrush" Color="{StaticResource LcAccentSoftColor}"/>
    <SolidColorBrush x:Key="LcAccentPaleBrush" Color="{StaticResource LcAccentPaleColor}"/>
    <SolidColorBrush x:Key="LcTextBrush" Color="{StaticResource LcTextColor}"/>
    <SolidColorBrush x:Key="LcTextMutedBrush" Color="{StaticResource LcTextMutedColor}"/>
    <SolidColorBrush x:Key="LcBorderBrush" Color="{StaticResource LcBorderColor}"/>
    <SolidColorBrush x:Key="LcBorderStrongBrush" Color="{StaticResource LcBorderStrongColor}"/>
    <SolidColorBrush x:Key="LcKeyEdgeBrush" Color="{StaticResource LcKeyEdgeColor}"/>
    <SolidColorBrush x:Key="LcToggleOffBrush" Color="{StaticResource LcToggleOffColor}"/>
    <SolidColorBrush x:Key="LcErrorBrush" Color="{StaticResource LcErrorColor}"/>
    <SolidColorBrush x:Key="LcSuccessBrush" Color="{StaticResource LcSuccessColor}"/>
    <SolidColorBrush x:Key="LcWindowTitleBrush" Color="{StaticResource LcWindowTitleColor}"/>
</ResourceDictionary>
